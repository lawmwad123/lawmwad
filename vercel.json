{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/admin/**/*.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/admin/index.html" }
  ]
}
